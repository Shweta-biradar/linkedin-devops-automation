# LinkedIn API Configuration
# Get your access token from: https://developer.linkedin.com/
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Get your member ID from LinkedIn API or profile
LINKEDIN_MEMBER_ID=your_numeric_member_id_here

# Optional: Author URN (alternative to member ID)
# LINKEDIN_AUTHOR_URN=urn:li:person:your_author_urn

# Posting Configuration
DRY_RUN=false
FORCE_FORMAT=auto

# Scheduling (UTC times)
HIRING_PITCH_MORNING_TIME=09:00
HIRING_PITCH_EVENING_TIME=18:00

# AI Features
ENABLE_AI_ENHANCE=true
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Other settings
TIMEZONE=UTC

# NOTE: For GitHub Actions automation, add these as repository secrets:
# https://github.com/Shweta-biradar/linkedin-devops-automation/settings/secrets/actions
# - LINKEDIN_ACCESS_TOKEN
# - LINKEDIN_MEMBER_ID
# - GROQ_API_KEY (optional)
# - GEMINI_API_KEY (optional)